# PatchHive Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/patchhive

# Backend API
SECRET_KEY=your-secret-key-here-generate-with-openssl
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_NAME=PatchHive
APP_VERSION=1.0.0
ABX_CORE_VERSION=1.3
ENFORCE_SEED_TRACEABILITY=true
ENVIRONMENT=development

# Canonical scope gates: historical surfaces are disabled by default.
ENABLE_LEGACY_SOCIAL=false
ENABLE_LEGACY_PUBLISHING=false
ENABLE_LEGACY_LEADERBOARDS=false
ENABLE_LEGACY_REFERRALS=false
# Transitional: legacy POST /api/export/runs/{id}/patchbook debit. Prefer /api/canon/exports.
ENABLE_LEGACY_PATCHBOOK_DEBIT=false

# Payments remain test-only. Production activation requires a separate reviewed change.
STRIPE_TEST_MODE=true
ALLOW_PRODUCTION_PAYMENTS=false
STRIPE_WEBHOOK_SECRET=
# Optional; defaults to SECRET_KEY when >= 32 bytes.
DOWNLOAD_TOKEN_SECRET=

# Frontend
VITE_API_URL=http://localhost:8000
